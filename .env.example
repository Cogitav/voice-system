VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_anon_key

# Base public URL used to generate chat widget embed snippets and public chat
# links shown in /admin/widgets. If omitted, the app falls back to
# window.location.origin (the origin currently serving the admin panel).
VITE_APP_PUBLIC_URL=https://your-production-domain.com
